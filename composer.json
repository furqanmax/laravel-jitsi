{
  "name": "vcmeet/laravel-jitsi",
  "description": "Meeting management package extracted from Laravel application",
  "type": "library",
  "license": "MIT",
  "authors": [
    {
      "name": "VC Meet Team",
      "email": "team@vcmeet.com"
    }
  ],
  "require": {
    "php": "^8.0",
    "laravel/framework": "^9.0|^10.0|^11.0"
  },
  "require-dev": {
    "orchestra/testbench": "^8.0|^9.0",
    "phpunit/phpunit": "^10.0|^11.0"
  },
  "autoload": {
    "psr-4": {
      "VcMeet\\Jitsi\\": "src/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "VcMeet\\Jitsi\\Tests\\": "tests/"
    }
  },
  "extra": {
    "laravel": {
      "providers": [
        "VcMeet\\Jitsi\\JitsiServiceProvider"
      ],
      "aliases": {
        "Jitsi": "VcMeet\\Jitsi\\Facades\\Jitsi"
      }
    }
  },
  "minimum-stability": "stable",
  "prefer-stable": true
}
